# Copy to .env and edit. These map to the CLI flags.
WALLET_ADDRESS=prl1pYOURWALLETADDRESSHERE
WORKER_NAME=tpu1
POOL=us1.alphapool.tech:5566
# AlphaPool minimum static difficulty is 20000; omit ;d= to use vardiff.
POOL_PASSWORD=x;d=20000
LOG_LEVEL=INFO
# Force the TPU backend on a Cloud TPU VM:
JAX_PLATFORMS=tpu
# Optional: override the tiled-scan rows-per-batch (default: auto).
# PRL_RBATCH=8
# Worker index override (auto-detected from jax.process_index() on pods).
# WORKER_INDEX=0
# Column-batch tiling for reduced HBM traffic (default: auto).
# PRL_NCBATCH=128
